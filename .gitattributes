# Preserve cross-platform defaults while keeping source/resource files LF.
# https://help.github.com/articles/dealing-with-line-endings/
*               text=auto eol=lf

# Linux start scripts stay LF
/gradlew        text eol=lf
*.sh            text eol=lf

# Windows launchers stay CRLF
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Treat packaged assets as binary
*.png           binary